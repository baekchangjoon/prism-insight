$schema: ../../schema/mcp-agent.config.schema.json

execution_engine: asyncio
logger:
  type: console
  level: info
  batch_size: 100
  flush_interval: 2
  max_queue_size: 2048
  http_endpoint:
  http_headers:
  http_timeout: 5

mcp:
  servers:
    webresearch:
      command: "npx"
      args: [ "-y", "@mzxrai/mcp-webresearch@latest" ]
      read_timeout_seconds: 120

    firecrawl:
        command: "npx"
        args: [ "-y", "firecrawl-mcp" ]
        env:
          FIRECRAWL_API_KEY: "example key"
        # Batch runs spawn the firecrawl MCP server many times back-to-back
        # (one MCPApp lifecycle per stock × per section); under load
        # firecrawl_scrape can take >60s to return. Match webresearch's
        # tolerance so we don't lose the 2.1 기업현황 section silently.
        read_timeout_seconds: 120

    kospi_kosdaq:
      command: "python3"
      args:
        [
          "-m",
          "kospi_kosdaq_stock_server"
        ]
      env:
        # Option 1: KRX Direct Login (Recommended)
        KRX_ID: "your_krx_id"
        KRX_PW: "your_krx_password"
        KRX_LOGIN_METHOD: "krx"  # "krx" (default) or "kakao"
        # Option 2: Kakao SNS Login (uncomment if using Kakao)
        # KAKAO_ID: "your_kakao_id"
        # KAKAO_PW: "your_kakao_password"
        # KRX_LOGIN_METHOD: "kakao"

    perplexity:
      command: "npx"
      args:
        [
          "-y",
          "@perplexity-ai/mcp-server"
        ]
      env:
        PERPLEXITY_API_KEY: "example key"

    sqlite:
      command: "uv"
      args:
        [
          "--directory",
          "sqlite",
          "run",
          "mcp-server-sqlite",
          "--db-path",
          "stock_tracking_db"
        ]

    time:
      command: "uvx"
      args:
        [
          "mcp-server-time"
        ]

    # ==========================================================================
    # US Stock Market Servers (prism-us module)
    # ==========================================================================

    # Yahoo Finance MCP server for US stock data (PyPI: yahoo-finance-mcp)
    # Python-based, uses stable yfinance library (not deprecated yahoo-finance2)
    # Provides: OHLCV, company info, financials, institutional holders, news, recommendations
    yahoo_finance:
      command: "uvx"
      args: ["--from", "yahoo-finance-mcp", "yahoo-finance-mcp"]
      read_timeout_seconds: 120

    # SEC EDGAR MCP server for official SEC filings and financial data (PyPI: sec-edgar-mcp)
    # FREE - no API key required, just user agent for rate limiting
    # Provides: 10-K/10-Q/8-K filings, XBRL financials, insider trading
    sec_edgar:
      command: "uvx"
      args: ["--from", "sec-edgar-mcp", "sec-edgar-mcp"]
      env:
        SEC_EDGAR_USER_AGENT: "YourCompany (your-email@example.com)"
      read_timeout_seconds: 120

openai:
  # Secrets (API keys, etc.) are stored in an mcp_agent.secrets.yaml file which can be gitignored
  default_model: gpt-5.1
  reasoning_effort: high

# ==========================================================================
# Multi-LLM-provider configuration (v2.14.0+)
# ==========================================================================
# Selects which provider + model each agent role uses. Everything is optional:
# if the `llm:` block is missing entirely, prism-insight falls back to the
# pre-v2.14 hardcoded model choices (openai/gpt-5.4-mini for analysis,
# anthropic/claude-sonnet-4-6 for strategist, openai/gpt-5.5 for trading,
# etc.), so this section only needs to be filled in if you actually want to
# change something.
#
# Resolution precedence (highest first):
#   1. PRISM_LLM_PROVIDER_<ROLE> / PRISM_LLM_MODEL_<ROLE> env vars
#   2. PRISM_LLM_PROVIDER / PRISM_LLM_MODEL env vars (global)
#   3. llm.roles.<role>.{provider,model} here
#   4. llm.default.{provider,model} here
#   5. Built-in role default
#
# Supported providers: openai | anthropic | google | grok
# Put each provider's API key in mcp_agent.secrets.yaml (see the example
# secrets file for keys: openai.api_key / anthropic.api_key / google.api_key
# / grok.api_key).
#
# Example A — keep everything default (just delete or comment out the whole
# llm: block, or leave it empty: `llm: {}`).
#
# Example B — replace OpenAI with Gemini for analysis/translator/summary,
# keep Anthropic for the strategist and Insight Q&A:
#
#   llm:
#     default:
#       provider: google
#       model: gemini-2.5-flash
#     roles:
#       strategist:
#         provider: anthropic
#         model: claude-sonnet-4-6
#       insight:
#         provider: anthropic
#         model: claude-sonnet-4-6
#       trading:
#         provider: openai          # keep OpenAI Responses API for trading
#         model: gpt-5.5
#
# Example C — run everything on a single Gemini key (lowest cost):
#
#   llm:
#     default:
#       provider: google
#       model: gemini-2.5-flash
#     roles:
#       strategist:
#         model: gemini-2.5-pro      # bigger model for the integrator
#
# Roles in use:
#   analysis   — the 6 KR/US analysis agents (price, flow, financial,
#                industry, news, market)
#   summary    — executive summary agent
#   strategist — Investment Strategist (cross-section integrator)
#   insight    — /insight archive Q&A agent
#   trading    — Buy/Sell Specialist (OpenAI Responses API used only when
#                provider == openai; other providers fall back to standard
#                chat-style completion automatically)
#   translator — Telegram broadcast translator + company-name translator

# llm:
#   default:
#     provider: openai
#     model: gpt-5.4-mini
#   roles:
#     analysis:
#       provider: openai
#       model: gpt-5.4-mini
#     strategist:
#       provider: anthropic
#       model: claude-sonnet-4-6
#     insight:
#       provider: anthropic
#       model: claude-sonnet-4-6
#     trading:
#       provider: openai
#       model: gpt-5.5
#     translator:
#       provider: openai
#       model: gpt-5-nano
