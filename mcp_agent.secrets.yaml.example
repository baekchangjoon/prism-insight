$schema: ../../schema/mcp-agent.config.schema.json

# Provider API keys. Only the providers you actually configure in the
# `llm:` section of mcp_agent.config.yaml need a real key here. Unconfigured
# providers can be left as the placeholder or commented out.

openai:
  api_key: example key

anthropic:
  api_key: example key

# Multi-LLM-provider support (v2.14.0+). Uncomment the ones you use.
# google:
#   api_key: AIza...                  # Google Gemini API key
# grok:
#   api_key: xai-...                  # xAI Grok API key
#   base_url: https://api.x.ai/v1     # Grok uses OpenAI-compatible API
